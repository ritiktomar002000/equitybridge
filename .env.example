# EquityBridge — Environment Variables
# Copy to .env and fill in your values

# ── SERVER ───────────────────────────────
PORT=3000
NODE_ENV=development

# ── POSTGRESQL ───────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=equitybridge
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# ── JWT ──────────────────────────────────
JWT_SECRET=change_this_to_a_random_64_char_string_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_EXPIRES_IN=7d

# ── REG CF ───────────────────────────────
MIN_INVESTMENT_AMOUNT=250
PLATFORM_FEE_PERCENT=2.5
MAX_CAMPAIGN_DURATION=90
